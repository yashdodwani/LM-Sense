# LM-Sense — environment variables template
# Purpose: copy this to .env and fill in your values before running the app
# Never commit .env to version control

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
DEBUG=true                                 # Set false in production

# ── LLM Providers (at least one required) ─────────────────────────────────────
OPENAI_API_KEY=sk-...                      # OpenAI API key
ANTHROPIC_API_KEY=sk-ant-...              # Anthropic API key
GEMINI_API_KEY=...                         # Google Gemini API key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lmsense:lmsense@localhost:5432/lmsense

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Debiasing pipeline ────────────────────────────────────────────────────────
REWARD_MODEL=gpt-4o                        # AI judge model for RLDF layer
FAIRNESS_LAMBDA=0.7                        # 0.0 = fluency only, 1.0 = fairness only
BIAS_THRESHOLD=0.6                         # Flag outputs with score below this (0–1)
LAYER1_ENABLED=true                        # QLoRA + CDA layer
LAYER2_ENABLED=true                        # RLDF layer
LAYER3_ENABLED=true                        # RL post-processing layer

# ── Rate limiting ─────────────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=60                 # Per tenant, sliding window

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]  # Add your frontend URL

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=                                # Leave blank to disable Sentry
WANDB_API_KEY=                             # Leave blank to disable W&B logging